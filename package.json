{
  "name": "mcp-embedded-ui",
  "version": "0.3.1",
  "description": "A lightweight, minimal-dependency embedded Web UI for any MCP Server.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/explorer.html','dist/explorer.html')\"",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "ui",
    "explorer",
    "tools",
    "model-context-protocol",
    "http",
    "express",
    "hono"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "src/explorer.html",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aiperceivable/mcp-embedded-ui-typescript.git"
  },
  "homepage": "https://github.com/aiperceivable/mcp-embedded-ui",
  "bugs": {
    "url": "https://github.com/aiperceivable/mcp-embedded-ui-typescript/issues"
  }
}